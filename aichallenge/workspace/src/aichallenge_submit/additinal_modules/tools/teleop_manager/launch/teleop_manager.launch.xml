<launch>

  <arg name="teleop_param"  default="$(find-pkg-share teleop_manager)/config/teleop.param.yaml"/>
  <arg name="self_control_topic" default="/ackermann_cmd"/>
  <arg name="auto_drive_topic" default="/awsim/raw_control_cmd"/>
  <arg name="trigger_topic" default="/rosbag2_recorder/trigger"/>

  
  <!-- joynode -->
  <node pkg="joy" 
        exec="joy_node"
        name="joy_node"
        output="screen">
    <param name="deadzone" value="0.05"/>
  </node>

  <!-- joy manager node-->
  <node pkg="teleop_manager"
        exec="teleop_manager_node"
        name="teleop_manager_node"
        output="screen">
        
    <param from="$(var teleop_param)"/>
    <!-- joy -->
    <remap from="/joy" to="/joy"/>
    <!-- 自律走行　コマンド -->
    <remap from="/ackermann_cmd" to="$(var self_control_topic)"/>
    <!-- AWSIMへの入力 -->
    <remap from="/cmd_drive" to="$(var auto_drive_topic)"/> 
    <!-- rosbag制御トリガ -->
    <remap from="/rosbag2_recorder/trigger" to="$(var trigger_topic)"/>
    <!-- offset トリガ -->
    <remap from="/steer_offset_inc" to="/steer_offset_inc"/>
    <remap from="/steer_offset_dec" to="/steer_offset_dec"/>
    <remap from="/speed_offset_inc" to="/speed_offset_inc"/>
    <remap from="/speed_offset_dec" to="/speed_offset_dec"/>
    
  </node>

</launch>
