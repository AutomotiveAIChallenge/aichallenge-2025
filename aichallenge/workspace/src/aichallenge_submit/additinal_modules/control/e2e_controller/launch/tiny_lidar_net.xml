<launch>

  <arg name="tiny_lidar_net_node_param"  default="$(find-pkg-share e2e_controller)/config/tiny_lidar_net_node.param.yaml"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="control_cmd_topic" default="/awsim/control_cmd"/>
  <arg name="ckpt_path" default="$(find-pkg-share e2e_controller)/ckpt/tiny_lidar_net_weights.npz"/>

  <!-- tiny_lidar_net_node -->
  <node pkg="e2e_controller" 
        exec="tiny_lidar_net_node"
        name="tiny_lidar_net_node"
        output="screen">

    <param from="$(var tiny_lidar_net_node_param)"/>
    <param name="model.ckpt_path" value="$(var ckpt_path)"/>
    <remap from="/scan" to="$(var scan_topic)"/>
    <remap from="/awsim/control_cmd" to="$(var control_cmd_topic)"/>
  </node>


</launch>