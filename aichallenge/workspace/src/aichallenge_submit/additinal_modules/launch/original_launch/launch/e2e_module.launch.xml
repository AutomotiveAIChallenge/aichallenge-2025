<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="csv_path" default="$(find-pkg-share scan_generator)/map/lane.csv"/>

    <include file="$(find-pkg-share scan_generator)/launch/scan_generator.launch.xml" >
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="csv_path" value="$(var csv_path)"/>
    </include>

    <include file="$(find-pkg-share teleop_manager)/launch/teleop_manager.launch.xml" >
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
</launch>